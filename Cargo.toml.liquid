[package]
authors    = ["natepiano"]
edition    = "2024"
homepage   = "https://github.com/natepiano/{{project-name}}"
license    = "MIT OR Apache-2.0"
name       = "{{project-name}}"
repository = "https://github.com/natepiano/{{project-name}}"
version    = "0.1.0"

[lints.clippy]
# Our strict lints
allow_attributes_without_reason = "deny"
expect_used                     = "deny"
panic                           = "deny"
unwrap_used                     = "deny"

# Enable lint groups as errors (with lower priority so allows can override)
all      = { level = "deny", priority = -1 }
cargo    = { level = "deny", priority = -1 }
nursery  = { level = "deny", priority = -1 }
pedantic = { level = "deny", priority = -1 }

# Allow specific lints that conflict with common patterns
multiple_crate_versions = "allow"
needless_pass_by_value  = "allow"

[lints.rust]
missing_docs = "deny"

[dependencies]
