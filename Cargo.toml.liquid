[package]
authors    = ["natepiano"]
edition    = "2024"
homepage   = "https://github.com/natepiano/{{project-name}}"
license    = "MIT OR Apache-2.0"
name       = "{{project-name}}"
repository = "https://github.com/natepiano/{{project-name}}"
version    = "0.1.0"

[lints.clippy]
# Our strict lints
allow_attributes_without_reason = "deny"
expect_used                     = "deny"
self_named_module_files         = "deny" # use module/mod.rs (directory form) when a module has submodules
panic                           = "deny"
unreachable                     = "deny"
unwrap_used                     = "deny"

# Enable lint groups as errors (with lower priority so allows can override)
all      = { level = "deny", priority = -1 }
cargo    = { level = "deny", priority = -1 }
nursery  = { level = "deny", priority = -1 }
pedantic = { level = "deny", priority = -1 }

# Allow specific lints that conflict with common patterns
multiple_crate_versions = "allow" # Transitive deps — out of our control
redundant_pub_crate     = "allow" # cargo mend is the visibility authority, not clippy
{% if bevy %}
# Bevy-specific allows: Bevy systems and queries inherently produce complex types
# and long parameter lists, the prelude convention relies on wildcard imports, and
# reflect macros trigger false positives in option_if_let_else.
needless_pass_by_value = "allow" # Bevy systems require owned params
option_if_let_else     = "allow" # False positives with Bevy reflect macros
too_many_arguments     = "allow" # Bevy systems often require many params
type_complexity        = "allow" # Bevy query types are inherently complex
wildcard_imports       = "allow" # Bevy prelude convention
{% endif %}

[lints.rust]
missing_docs = "deny"

[dependencies]
